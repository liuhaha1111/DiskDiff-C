<Window x:Class="DiskDiff.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:DiskDiff.App.ViewModels"
        mc:Ignorable="d"
        Title="DiskDiff"
        Height="760"
        Width="1280"
        MinHeight="640"
        MinWidth="960">
    <Window.Resources>
        <HierarchicalDataTemplate DataType="{x:Type viewModels:FolderTreeItemViewModel}"
                                  ItemsSource="{Binding Children}">
            <DockPanel Margin="0,2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding Name}" />
                    <TextBlock Margin="10,0,0,0"
                               Foreground="DimGray"
                               Text="{Binding LogicalBytes, StringFormat=N0}" />
                    <TextBlock Margin="10,0,0,0"
                               Foreground="SteelBlue"
                               Text="{Binding LogicalDelta, StringFormat={}{0:+#,#;-#,#;0}}" />
                </StackPanel>
            </DockPanel>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                Margin="0,0,0,12"
                Background="#F5F7FA"
                BorderBrush="#D6DCE5"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="Drive" />
                    <ComboBox Width="120"
                              Margin="12,0,0,0"
                              ItemsSource="{Binding AvailableDrives}"
                              SelectedItem="{Binding SelectedDrive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Margin="12,0,0,0"
                            Padding="16,6"
                            Command="{Binding ScanNowCommand}"
                            Content="Scan Now" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Margin="24,0,0,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="{Binding StatusText}" />

                <TextBlock Grid.Column="2"
                           Margin="24,0,0,0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Text="{Binding LatestSnapshotSummary}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,0,0,12"
                Padding="10"
                Background="#FBFCFE"
                BorderBrush="#D6DCE5"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock FontWeight="SemiBold"
                       Text="{Binding SelectedDirectoryPath, StringFormat=Current directory: {0}}" />
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Directory Tree"
                      Padding="8">
                <TreeView ItemsSource="{Binding DirectoryTreeItems}"
                          SelectedItemChanged="DirectoryTree_OnSelectedItemChanged" />
            </GroupBox>

            <GridSplitter Grid.Column="1"
                          Width="12"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent" />

            <GroupBox Grid.Column="2"
                      Header="Details"
                      Padding="8">
                <DataGrid x:Name="DetailsGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding DetailRows}"
                          MouseDoubleClick="DetailsGrid_OnMouseDoubleClick"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding Name}"
                                            Header="Name"
                                            Width="2*" />
                        <DataGridTextColumn Binding="{Binding EntryType}"
                                            Header="Type"
                                            Width="*" />
                        <DataGridTextColumn Binding="{Binding CurrentLogicalBytes, StringFormat=N0}"
                                            Header="Current Size"
                                            Width="*" />
                        <DataGridTextColumn Binding="{Binding LogicalDelta, StringFormat={}{0:+#,#;-#,#;0}}"
                                            Header="Delta"
                                            Width="*" />
                        <DataGridTextColumn Binding="{Binding ChangeType}"
                                            Header="Change"
                                            Width="*" />
                        <DataGridTextColumn Binding="{Binding ModifiedAtUtc, StringFormat=yyyy-MM-dd HH:mm:ss}"
                                            Header="Modified"
                                            Width="1.5*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <StatusBar Grid.Row="3"
                   Margin="0,12,0,0">
            <StatusBarItem Content="{Binding StatusText}" />
            <Separator />
            <StatusBarItem Content="{Binding ScannedItemCount, StringFormat=Items: {0:N0}}" />
            <Separator />
            <StatusBarItem Content="{Binding ElapsedTimeText, StringFormat=Elapsed: {0}}" />
            <Separator />
            <StatusBarItem Content="{Binding ErrorCount, StringFormat=Errors: {0}}" />
        </StatusBar>
    </Grid>
</Window>
